# Local development environment variables
# Copy this file to .env.local and fill in any required values.
# .env.local is gitignored — never commit secrets.

# ── OpenRouter (required for L3/L4 LLM calls) ────────────────────────────────
OPENROUTER_API_KEY=<your-openrouter-api-key>

# ── Pinecone (local emulator — no real key needed locally) ───────────────────
PINECONE_API_KEY=local
PINECONE_HOST=http://pinecone-local:5081
PINECONE_INDEX_NAME=astra-icons

# ── S3 / MinIO (local emulator) ───────────────────────────────────────────────
AWS_ENDPOINT_URL=http://minio:9000
ICONS_BUCKET_NAME=astra-icons-local
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# ── Lambda / API server ───────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
TABLE_NAME=astra-skeletons
OPENROUTER_API_KEY_PARAM=/astra/openrouter-api-key
